# Contact Form / Lead notifications (Resend)
RESEND_API_KEY=
CONTACT_EMAIL=hello@newagecontent.com
# Verified Resend sender for tier lead notifications (/start, /grow, /scale).
LEAD_FROM_EMAIL="New Age Leads <leads@newagecontent.com>"
# Comma-separated recipients for new tier leads. Defaults to both inboxes below.
LEAD_NOTIFY_TO=hello@newagecontent.com,bojodanchev@gmail.com

# Analytics (Phase 2)
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=newagecontent.com

# Booking (Phase 2)
NEXT_PUBLIC_CALENDLY_URL=

# CRM (Phase 2)
HUBSPOT_API_KEY=

# Turso Database
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Meta Ads Funnel — tracking
# Public Pixel ID is also used as the dataset ID for CAPI.
NEXT_PUBLIC_META_PIXEL_ID=
# Server-only — generate in Events Manager → Settings → CAPI → Generate access token.
META_CAPI_ACCESS_TOKEN=
# Optional — use a test event code from Events Manager → Test events tab.
META_CAPI_TEST_EVENT_CODE=
# GA4 measurement ID (format: G-XXXXXXXXXX). When set, /meta-ads loads gtag.js.
NEXT_PUBLIC_GA4_ID=

# Admin — /admin lead viewer
# Override the default password "admin123". Use a strong value in production.
ADMIN_PASSWORD=
